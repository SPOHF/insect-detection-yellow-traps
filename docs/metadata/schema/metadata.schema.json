{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spohf.github.io/insect-detection-yellow-traps/metadata/v1.0.0",
  "title": "Trap Upload Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "field_id",
    "trap_code",
    "capture_date",
    "capture_time",
    "timezone",
    "device_id",
    "operator_id"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1.0.0"
    },
    "field_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "trap_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "capture_date": {
      "type": "string",
      "format": "date"
    },
    "capture_time": {
      "type": "string",
      "pattern": "^([01]\\d|2[0-3]):[0-5]\\d(:[0-5]\\d)?$"
    },
    "timezone": {
      "type": "string",
      "examples": ["Europe/Berlin", "UTC"]
    },
    "device_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "operator_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "notes": {
      "type": "string",
      "maxLength": 1000
    },
    "gps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lon"],
      "properties": {
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "weather": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "temperature_c": {
          "type": "number",
          "minimum": -50,
          "maximum": 60
        },
        "humidity_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "rain_mm": {
          "type": "number",
          "minimum": 0,
          "maximum": 1000
        }
      }
    }
  }
}
